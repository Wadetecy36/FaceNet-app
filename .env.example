# ─── LAN Inference Server (yolo_server.py) ───────────────────────────────────
# Copy this block to the STRONGER LAN machine

# 1. Install Python deps
INFERENCE_PYTHON_DEPS="fastapi uvicorn ultralytics opencv-python-headless requests pillow"

# 2. Install Ollama + pull Qwen
# curl -fsSL https://ollama.com/install.sh | sh
# ollama pull qwen2.5:7b       # ~4.7GB — use qwen2.5:3b if RAM is tight (~2GB)

# 3. Run
# uvicorn yolo_server:app --host 0.0.0.0 --port 8000

# ─── FaceNet-Node edge device (.env) ─────────────────────────────────────────

# URL of your LAN inference server (the stronger PC's local IP)
INFERENCE_SERVER=http://192.168.1.50:8000

# Unique ID for this edge device
DEVICE_ID=edge-device-1

# Human-readable location label (shows up in logs and anomaly alerts)
LOCATION=Main Entrance

# Optional: your existing Flask-SQLAlchemy endpoint to also persist anomaly records
# Leave blank to disable
FLASK_URL=http://localhost:5000/api/anomalies

# ─── Notes ────────────────────────────────────────────────────────────────────
# - Logs are written to ./logs/events.ndjson on the edge device
# - High-severity anomalies print to console in red immediately
# - All results + anomalies are broadcast to connected dashboard WebSocket clients
# - GET /api/logs?session=xxx&anomalies_only=true&severity=high for filtered queries
